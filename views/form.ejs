<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>New Message - Mini Messageboard</title>
    <style>
      body {
        font-family: sans-serif;
        max-width: 600px;
        margin: 2rem auto;
        padding: 0 1rem;
      }
      .form-group {
        margin-bottom: 1rem;
      }
      label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: bold;
      }
      input[type="text"],
      textarea {
        width: 100%;
        padding: 0.5rem;
        border: 1px solid #ccc;
        border-radius: 4px;
        box-sizing: border-box;
      }
      button {
        background: #0066cc;
        color: white;
        padding: 0.5rem 1rem;
        border: none;
        border-radius: 4px;
        cursor: pointer;
      }
      button:hover {
        background: #0052a3;
      }
      a {
        color: #0066cc;
        text-decoration: none;
        margin-left: 1rem;
      }
    </style>
  </head>
  <body>
    <h1>Add a New Message</h1>
    
    <% if (errors && errors.length > 0) { %>
      <div style="color: red; margin-bottom: 1rem; border: 1px solid red; padding: 1rem;">
        <ul>
          <% errors.forEach(error => { %>
            <li><%= error.msg %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>
    
    <form method="POST" action="/new">
      <div class="form-group">
        <label for="messageUser">Author's Name:</label>
        <input type="text" id="messageUser" name="messageUser" required />
      </div>

      <div class="form-group">
        <label for="messageText">Message Text:</label>
        <textarea
          id="messageText"
          name="messageText"
          rows="4"
          required
        ></textarea>
      </div>

      <button type="submit">Submit</button>
      <a href="/">Cancel</a>
    </form>
  </body>
</html>
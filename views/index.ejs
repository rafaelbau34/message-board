<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Mini Messageboard</title>
  <style>
    body { font-family: sans-serif; max-width: 600px; margin: 2rem auto; padding: 0 1rem; }
    .message { border: 1px solid #ccc; padding: 1rem; margin-bottom: 1rem; border-radius: 4px; }
    .message-header { display: flex; justify-content: space-between; margin-bottom: 0.5rem; }
    .user { font-weight: bold; }
    .date { color: #666; font-size: 0.9em; }
    .actions { margin-top: 1rem; }
    a { color: #0066cc; text-decoration: none; }
    a:hover { text-decoration: underline; }
    .btn { display: inline-block; background: #0066cc; color: white; padding: 0.5rem 1rem; border-radius: 4px; }
    .btn:hover { background: #0052a3; text-decoration: none; }
  </style>
</head>
<body>
  <h1>Mini Messageboard</h1>
  
  <% messages.forEach(function(msg, index) { %>
    <div class="message">
      <div class="message-header">
        <span class="user"><%= msg.user %></span>
        <span class="date"><%= msg.added.toLocaleString() %></span>
      </div>
      <p><%= msg.text %></p>
      <div class="actions">
        <a href="/message/<%= index %>">Open</a>
      </div>
    </div>
  <% }); %>

  <div style="margin-top: 2rem;">
    <a href="/new" class="btn">Add New Message</a>
  </div>
</body>
</html>

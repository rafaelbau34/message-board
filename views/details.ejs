<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Message Details - Mini Messageboard</title>
    <style>
      body {
        font-family: sans-serif;
        max-width: 600px;
        margin: 2rem auto;
        padding: 0 1rem;
      }
      .message-details {
        border: 1px solid #ccc;
        padding: 2rem;
        border-radius: 4px;
        background: #f9f9f9;
      }
      .user {
        font-size: 1.2em;
        font-weight: bold;
        margin-bottom: 0.5rem;
      }
      .date {
        color: #666;
        margin-bottom: 1.5rem;
      }
      .text {
        font-size: 1.1em;
        line-height: 1.5;
      }
      .back-link {
        display: inline-block;
        margin-top: 2rem;
        color: #0066cc;
        text-decoration: none;
      }
      .back-link:hover {
        text-decoration: underline;
      }
    </style>
  </head>
  <body>
    <h1>Message Details</h1>

    <div class="message-details">
      <div class="user"><%= message.user %></div>
      <div class="date"><%= message.added.toLocaleString() %></div>
      <div class="text"><%= message.text %></div>
    </div>

    <a href="/" class="back-link">&larr; Back to all messages</a>
  </body>
</html>
